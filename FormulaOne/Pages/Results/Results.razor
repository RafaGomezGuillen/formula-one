@page "/Results"
@inject HttpClient Http

<PageTitle> Results </PageTitle>

<Layout>
    <LayoutHeader Fixed="true">
        <Header />
    </LayoutHeader>
    <LayoutContent style="margin-top: 55px; position: absolute; width: 100%;">
        <Jumbotron style="border-bottom: solid grey 5px; border-right: solid grey 5px; border-bottom-right-radius: 10px;">
            <JumbotronTitle Size="JumbotronTitleSize.Is4">
                <h1 style="font-size: 42px; line-height: 48px; letter-spacing: 0.2px">
                    Results
                </h1>
            </JumbotronTitle>
            <Divider></Divider>
            <div class="season-summary-content">
                <div class="season-summary-p">
                    <h1>Driver Standings</h1>
                    <p>
                        The 2022 season saw the arrival of a new generation of cars, designed to allow for even closer racing. Ferrari initially took full advantage, with Charles Leclerc 
                        returning the Scuderia to winning ways, but their title challenge ultimately faded in the face of a relentless Max Verstappen and Red Bull team, who secured 
                        their first championship double since 2013. Mercedes were the only other team to win a race, but it was George Russell who took a celebrated maiden victory, 
                        as team mate Lewis Hamilton failed to top a podium for the first time in his illustrious F1 career.
                    </p>
                </div>
                <div class="season-summary-img">
                    <img src="/img/Summary.jpg"/>
                </div>
            </div>
            @if (ListStandings == null)
            {
                <p><em>Loading...</em></p>
            }
            else
            {
                <div class="circuit-results">
                    <Table Striped>
                    <TableHeader>
                        <TableRow>
                            <TableHeaderCell>POS</TableHeaderCell>
                            <TableHeaderCell>NO</TableHeaderCell>
                            <TableHeaderCell>DRIVER</TableHeaderCell>
                            <TableHeaderCell>CAR</TableHeaderCell>
                            <TableHeaderCell>POINTS</TableHeaderCell>
                        </TableRow>
                    </TableHeader>
                    <TableBody>
                        @foreach (var elem in ListStandings.OrderByDescending(p => p.Points))
                        {
                            <TableRow>
                                <TableRowCell>@elem.Pos</TableRowCell>
                                <TableRowCell>@elem.DriverNumber</TableRowCell>
                                <TableRowCell>@elem.Driver</TableRowCell>
                                <TableRowCell>@elem.Car</TableRowCell>
                                <TableRowCell>@elem.Points</TableRowCell>
                            </TableRow>
                        }
                        </TableBody>
                    </Table>
                </div>
            }
            <br />
            <br />
            <div class="season-summary-content">
                <div class="season-summary-p">
                    <h1>Constructor Standings</h1>
                    <p>
                        Max Verstappen won his second consecutive World Drivers Championship driving for Red Bull Racing. 
                        Charles Leclerc finished runner-up, driving for Ferrari. Sergio Pérez was third, driving for Red Bull Racing. 
                        Red Bull Racing won their fifth World Constructors Championship.
                    </p>
                </div>
                <div class="season-summary-img">
                    <img src="/img/teams/red-bull/img-2.jpg"/>
                </div>
            </div>
            @if (ListStandings == null)
            {
                <p><em>Loading...</em></p>
            }
            else
            {
                <div class="circuit-results">
                    <Table Striped>
                    <TableHeader>
                        <TableRow>
                            <TableHeaderCell>POS</TableHeaderCell>
                            <TableHeaderCell>TEAM</TableHeaderCell>
                            <TableHeaderCell>POINTS</TableHeaderCell>
                        </TableRow>
                    </TableHeader>
                    <TableBody>
                        @foreach (var elem in TeamStandings.OrderByDescending(p => p.Points))
                        {
                            <TableRow>
                                <TableRowCell>@elem.Pos</TableRowCell>
                                <TableRowCell>@elem.Team</TableRowCell>
                                <TableRowCell>@elem.Points</TableRowCell>
                            </TableRow>
                        }
                        </TableBody>
                    </Table>
                </div>
            }
            <br />
            <br />
            <h1 class="race-results">Driver Standings Statistics</h1>
            @if (DriverStats == null)
            {
                <p><em>Loading...</em></p>
            }
            else
            {
                <div class="circuit-results">
                    <Table Striped>
                    <TableHeader>
                        <TableRow>
                            <TableHeaderCell>POS</TableHeaderCell>
                            <TableHeaderCell>DRIVER</TableHeaderCell>
                            <TableHeaderCell>TEAM</TableHeaderCell>
                            <TableHeaderCell>GRAND PRIX</TableHeaderCell>
                            <TableHeaderCell>WINS</TableHeaderCell>
                            <TableHeaderCell>PODIUMS</TableHeaderCell>
                            <TableHeaderCell>POLE POSITIONS</TableHeaderCell>
                            <TableHeaderCell>FASTEST LAPS</TableHeaderCell>
                            <TableHeaderCell>LAPS LED</TableHeaderCell>
                            <TableHeaderCell>POINTS</TableHeaderCell>
                        </TableRow>
                    </TableHeader>
                    <TableBody>
                        @foreach (var elem in DriverStats.OrderByDescending(p => p.Points))
                            {
                                <TableRow>
                                    <TableRowCell>@elem.Pos</TableRowCell>
                                    <TableRowCell>@elem.Driver</TableRowCell>
                                    <TableRowCell>@elem.Team</TableRowCell>
                                    <TableRowCell>@elem.GrandPrix</TableRowCell>
                                    <TableRowCell>@elem.Wins</TableRowCell>
                                    <TableRowCell>@elem.Podiums</TableRowCell>
                                    <TableRowCell>@elem.PolePosition</TableRowCell>
                                    <TableRowCell>@elem.FastestLap</TableRowCell>
                                    <TableRowCell>@elem.LapsLed</TableRowCell>
                                    <TableRowCell>@elem.Points</TableRowCell>
                                </TableRow>
                            }
                        </TableBody>
                    </Table>
                </div>
            }
            <br />
            <br />
            <h1 class="race-results">Team Standings Statistics</h1>
            @if (ListStandings == null)
            {
                <p><em>Loading...</em></p>
            }
            else
            {
                <div class="circuit-results">
                    <Table Striped>
                    <TableHeader>
                        <TableRow>
                            <TableHeaderCell>POS</TableHeaderCell>
                            <TableHeaderCell>TEAM</TableHeaderCell>
                            <TableHeaderCell>CHASIS</TableHeaderCell>
                            <TableHeaderCell>ENGINE</TableHeaderCell>
                            <TableHeaderCell>GRAND PRIX</TableHeaderCell>
                            <TableHeaderCell>WINS</TableHeaderCell>
                            <TableHeaderCell>PODIUMS</TableHeaderCell>
                            <TableHeaderCell>POLE POSITIONS</TableHeaderCell>
                            <TableHeaderCell>FASTEST LAPS</TableHeaderCell>
                            <TableHeaderCell>LAPS LED</TableHeaderCell>
                            <TableHeaderCell>POINTS</TableHeaderCell>
                        </TableRow>
                    </TableHeader>
                    <TableBody>
                        @foreach (var elem in TeamStandings.OrderByDescending(p => p.Points))
                            {
                                <TableRow>
                                    <TableRowCell>@elem.Pos</TableRowCell>
                                    <TableRowCell>@elem.Team</TableRowCell>
                                    <TableRowCell>@elem.Chasis</TableRowCell>
                                    <TableRowCell>@elem.Engine</TableRowCell>
                                    <TableRowCell>@elem.GrandPrix</TableRowCell>
                                    <TableRowCell>@elem.Wins</TableRowCell>
                                    <TableRowCell>@elem.Podiums</TableRowCell>
                                    <TableRowCell>@elem.PolePositions</TableRowCell>
                                    <TableRowCell>@elem.FastestLaps</TableRowCell>
                                    <TableRowCell>@elem.LapsLed</TableRowCell>
                                    <TableRowCell>@elem.Points</TableRowCell>
                                </TableRow>
                            }
                        </TableBody>
                    </Table>
                </div>
            }
        </Jumbotron>
        <Footer />
    </LayoutContent>
</Layout>
@code {
    private static List<Root>? ListStandings = new List<Root>();
    private static List<Root2>? TeamStandings = new List<Root2>();
    private static List<Root3>? DriverStats = new List<Root3>();

    protected override async Task OnInitializedAsync ()
    {
        ListStandings = await Http.GetFromJsonAsync<List<Root>>("sample-data/TeamStands.json");
        TeamStandings = await Http.GetFromJsonAsync<List<Root2>>("sample-data/TeamStats.json");
        DriverStats = await Http.GetFromJsonAsync<List<Root3>>("sample-data/DriverStatistics.json");
    }

    public class Root
    {
        public int Pos { get; set; }
        public int DriverNumber { get; set; }
        public string? Driver { get; set; }
        public string? Car { get; set; }
        public int BHR { get; set; }
        public int ARA { get; set; }
        public int AUS { get; set; }
        public int EMI { get; set; }
        public int MIA { get; set; }
        public int ESP { get; set; }
        public int MON { get; set; }
        public int AZE { get; set; }
        public int CAN { get; set; }
        public int GBR { get; set; }
        public int AUT { get; set; }
        public int FRA { get; set; }
        public int HUN { get; set; }
        public int BEL { get; set; }
        public int NED { get; set; }
        public int ITA { get; set; }
        public int SIN { get; set; }
        public int JPN { get; set; }
        public int USA { get; set; }
        public int MEX { get; set; }
        public int SAO { get; set; }
        public int ABU { get; set; }
        public int Points { get; set; }
    }

    public class Root2
    {
        public int Pos { get; set; }
        public string? Team { get; set; }
        public string? Chasis { get; set; }
        public string? Engine { get; set; }
        public int GrandPrix { get; set; }
        public int Wins { get; set; }
        public int Podiums { get; set; }
        public int PolePositions { get; set; }
        public int FastestLaps { get; set; }
        public int LapsLed { get; set; }
        public int Points { get; set; }
    }

    public class Root3
    {
        public int Pos { get; set; }
        public string? Driver { get; set; }
        public string? Team { get; set; }
        public int GrandPrix { get; set; }
        public int Wins { get; set; }
        public int Podiums { get; set; }
        public int PolePosition { get; set; }
        public int FastestLap { get; set; }
        public int LapsLed { get; set; }
        public int Points { get; set; }
    }
}
