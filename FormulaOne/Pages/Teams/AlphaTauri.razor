                    </tr>
                    <tr>
                        <th>Team Chief</th>
                        <td>		Franz Tost</td>
                    </tr>
                    <tr>
                        <th>Technical Chief</th>
                        <td>		Jody Egginton</td>
                    </tr>
                    <tr>
                        <th>Chassis</th>
                        <td>
                    @if (VectorTeam == null)
                    {
                                        <p> loading</p>
                    }
                    else
                    {
                        @VectorTeam[10].ChassisAlias
                    }
                        </td>
                    </tr>
                    <tr>
                        <th>Power Unit</th>
