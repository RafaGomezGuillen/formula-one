@page "/Drivers/NicholasLatifi"
@inject HttpClient Http

<PageTitle>Nicholas Latifi</PageTitle>

<Jumbotron style="border-bottom: solid grey 5px; border-right: solid grey 5px; border-bottom-right-radius: 10px;">
    <JumbotronTitle Size="JumbotronTitleSize.Is4">
        <h1 style="font-size: 42px; line-height: 48px; letter-spacing: 0.2px">
            @if (VectorDrivers == null)
            {
                <p> loading</p>
            }
            else
            {
                @VectorDrivers[19].Driver
            }
        </h1>
    </JumbotronTitle>
    <Divider></Divider>
    <div class="row">
        <div class="column">
            <div class="driver-logo">
                <img src="/img/drivers-content/nicholas-latifi/logo.jpg" />
            </div>
            <div class="number-flag">
                @if (DriversNumbers == null)
                {
                    <p> loading</p>
                }
                else
                {
                    @DriversNumbers[19]
                }
                -
                @if (VectorDrivers == null)
                {
                    <p> loading</p>
                }
                else
                {
                    @VectorDrivers[19].Driver
                }
                <img src="/img/drivers/countries/Canada.jpg" />
            </div>
        </div>
        <div class="column">
            <div class="driver-helmet">
                <img src="/img/teams/williams/williams-logo.jpg" />
                <img src="/img/drivers-content/nicholas-latifi/helmet.png" />
            </div>
            <br />
            <div class="team-table">
                <table>
                    <tr>
                        <th>Position standing</th>
                        <td>
                            @if (VectorDrivers == null)
                            {
                                <p> loading</p>
                            }
                            else
                            {
                                @VectorDrivers[19].Pos
                            }
                        </td>
                    </tr>
                    <tr>
                        <th>Team</th>
                        <td>
                            @if (VectorDrivers == null)
                            {
                                <p> loading</p>
                            }
                            else
                            {
                                @VectorDrivers[19].Team
                            }
                        </td>
                    </tr>
                    <tr>
                        <th>Grand Prix entered</th>
                        <td>
                            @if (VectorDrivers == null)
                            {
                                <p> loading</p>
                            }
                            else
                            {
                                @VectorDrivers[19].GrandPrix
                            }
                        </td>
                    </tr>
                    <tr>
                        <th>Wins</th>
                        <td>
                            @if (VectorDrivers == null)
                            {
                                <p> loading</p>
                            }
                            else
                            {
                                @VectorDrivers[19].Wins
                            }
                        </td>
                    </tr>
                    <tr>
                        <th>Podiums</th>
                        <td>
                            @if (VectorDrivers == null)
                            {
                                <p> loading</p>
                            }
                            else
                            {
                                @VectorDrivers[19].Podiums
                            }
                        </td>
                    </tr>
                    <tr>
                        <th>Pole position</th>
                        <td>
                            @if (VectorDrivers == null)
                            {
                                <p> loading</p>
                            }
                            else
                            {
                                @VectorDrivers[19].PolePosition
                            }
                        </td>
                    </tr>
                    <tr>
                        <th>Fastest lap</th>
                        <td>
                            @if (VectorDrivers == null)
                            {
                                <p> loading</p>
                            }
                            else
                            {
                                @VectorDrivers[19].FastestLap
                            }
                        </td>
                    </tr>
                    <tr>
                        <th>Laps led</th>
                        <td>
                            @if (VectorDrivers == null)
                            {
                                <p> loading</p>
                            }
                            else
                            {
                                @VectorDrivers[19].LapsLed
                            }
                        </td>
                    </tr>
                    <tr>
                        <th>Points</th>
                        <td>
                            @if (VectorDrivers == null)
                            {
                                <p> loading</p>
                            }
                            else
                            {
                                @VectorDrivers[19].Points
                            }
                        </td>
                    </tr>
                </table>
            </div>
        </div>
    </div>
    <div class="carousel">
        <Carousel @bind-SelectedSlide="@selectedSlide" Crossfade="true" ShowControls="false" ShowIndicators="false" Interval="3000">
            <CarouselSlide Name="1">
                <img src="img/drivers-content/nicholas-latifi/img-1.jpg" />
            </CarouselSlide>
            <CarouselSlide Name="2">
                <img src="img/drivers-content/nicholas-latifi/img-2.jpg" />
            </CarouselSlide>
            <CarouselSlide Name="3">
                <img src="img/drivers-content/nicholas-latifi/img-3.jpg" />
            </CarouselSlide>
            <CarouselSlide Name="4">
                <img src="img/drivers-content/nicholas-latifi/img-4.jpg" />
            </CarouselSlide>
        </Carousel>
    </div>
    <div class="team-content">
        <h1>Biography</h1>
        <p>
            Thirteen is an advanced age to begin your karting career these days. But that’s how old Toronto native Nicholas Latifi was when he took his first steps in motorsport. Just 11 years later, he became a fully-fledged Formula 1 driver.
            <br />
            <br />
            That ascension into racing's top category was largely thanks to his most impressive season to date in Formula 2 in 2019, with Latifi – who’d finished a disappointing ninth in the series’ 2018 standings – pulling up his bootstraps to claim second in the championship. That result, combined with the Williams/Robert Kubica union failing to mesh in 2019, meant Williams made the call to promote their affable Canadian reserve driver to a full-time drive alongside George Russell for 2020.
            <br />
            <br />
            Latifi’s first taste of F1 machinery actually came all the way back in 2017, when he was given a test by Renault. Further duties with Force India followed in 2018 before he joined the Williams family in 2019. It was an annus horribilis for the squad, no doubt – but Latifi’s straightforward, friendly attitude and insightful feedback helped swing the vote in his favour for 2020.
            <br />
            <br />
            Now, after two seasons living in Russell’s shadow – and with Williams' form on the rise and a new team mate in the shape of ex-Red Bull racer Alex Albon – the goal is to show that that his eye-catching F2 year wasn’t just a fluke, and finally prove that he really has got what it takes to mix it with the best drivers in the world.
        </p>
        <h1>Results</h1>
        <p>20 includes P20, DNFs, DNSs, DWs and DNPs</p>
        <div style="width: 99%">
            <LineChart @ref="lineChart" TItem="WatcherEvent" Options="@lineChartOptions" />
        </div>
    </div>
    <CardDeck>
        <Card>
            <CardImage Source="/img/teams/williams/img-2.jpg"></CardImage>
            <CardBody>
                <CardTitle Size="5">
                    @if (VectorDrivers == null)
                    {
                        <p> loading</p>
                    }
                    else
                    {
                        @VectorDrivers[18].Driver
                    }
                </CardTitle>
                <CardText>
                    @if (VectorDrivers == null)
                    {
                        <p> loading</p>
                    }
                    else
                    {
                        @VectorDrivers[19].Driver
                    }
                    teammate.
                </CardText>
                <Button Margin="Margin.Is2.FromTop" Color="Color.Primary">
                    <Link To="/Drivers/AlexanderAlbon" TextColor="TextColor.White">
                    READ MORE <Icon Name="IconName.ArrowRight" />
                    </Link>
                </Button>
            </CardBody>
        </Card>
        <Card>
            <CardImage Source="/img/teams/williams/williams-logo.jpg" ></CardImage>
            <CardBody>
                <CardTitle Size="5">
                    @if (VectorDrivers == null)
                    {
                        <p> loading</p>
                    }
                    else
                    {
                        @VectorDrivers[19].Team
                    }
                </CardTitle>
                <CardText>
                    @if (VectorDrivers == null)
                    {
                        <p> loading</p>
                    }
                    else
                    {
                        @VectorDrivers[19].Driver
                    }
                    team.
                </CardText>
                <Button Margin="Margin.Is2.FromTop" Color="Color.Primary">
                    <Link To="/Teams/Williams" TextColor="TextColor.White">
                    READ MORE <Icon Name="IconName.ArrowRight" />
                    </Link>
                </Button>
            </CardBody>
        </Card>
        <Card>
            <CardImage Source="/img/Changes.jpg"></CardImage>
            <CardBody>
                <CardTitle Size="5">Drivers</CardTitle>
                <CardText>
                    Full drivers lineup.
                </CardText>
                <Button Margin="Margin.Is2.FromTop" Color="Color.Primary">
                    <Link To="/Drivers" TextColor="TextColor.White">
                    READ MORE <Icon Name="IconName.ArrowRight" />
                    </Link>
                </Button>
            </CardBody>
        </Card>
    </CardDeck>
</Jumbotron>

@*Theme*@
<Blazorise.ThemeProvider Theme="@theme">
    <Router AppAssembly="typeof(App).Assembly">
        <Found>...</Found>
        <NotFound>...</NotFound>
    </Router>
</Blazorise.ThemeProvider>

@code {
    private string selectedSlide = "1";

    private Theme theme = new Theme
    {
        ColorOptions = new ThemeColorOptions { Primary = "#E10600" }
    };

    private Root[]? VectorDrivers;
    private int[] DriversNumbers = { 1, 16, 11, 63, 55, 44, 4, 31, 14, 77, 3, 5, 20, 10, 18, 47, 22, 24, 23, 6 };

    protected override async Task OnInitializedAsync ()
    {
        VectorDrivers = await Http.GetFromJsonAsync<Root[]>("sample-data/DriverStatistics.json");
    }

    public class Root
    {
        public int Pos { get; set; }
        public string Driver { get; set; }
        public string Team { get; set; }
        public int GrandPrix { get; set; }
        public int Wins { get; set; }
        public int Podiums { get; set; }
        public int PolePosition { get; set; }
        public int FastestLap { get; set; }
        public int LapsLed { get; set; }
        public int Points { get; set; }
    }

    private LineChart<WatcherEvent> lineChart;

    LineChartOptions lineChartOptions = new()
        {
            Parsing = new ChartParsing
            {
                XAxisKey = "sector",
                YAxisKey = "count",
            }
        };

    string[] Labels = { "Bahrain", "Saudi Arabia", "Australia", "Emilia Romagna", "Miami", "Spain", "Monaco", "Azerbaijan", "Canada", "Great Britain", "Austria", "France",
                        "Hungary", "Belgium", "Netherlands", "Italy", "Singapore", "Japan", "United States", "Mexico", "Brazil", "Abu Dhabi"};


    private List<string> backgroundColors = new() { ChartColor.FromRgba(255, 99, 132, 0.2f) };
    private List<string> borderColors = new() { ChartColor.FromRgba(255, 99, 132, 1f) };

    private bool isAlreadyInitialised;

    public class WatcherEvent
    {
        public string Sector { get; set; }
        public int Count { get; set; }
    }

    protected override async Task OnAfterRenderAsync (bool firstRender)
    {
        if (!isAlreadyInitialised)
        {
            isAlreadyInitialised = true;
            await lineChart.Clear();
            await lineChart.AddDataSet(GetLineChartDataset());
        }
    }

    private LineChartDataset<WatcherEvent> GetLineChartDataset ()
    {
        return new()
            {
                Label = "Nicholas Latifi",
                Data = new List<WatcherEvent>
            {
                new WatcherEvent { Sector = Labels[0], Count = 16 },
                new WatcherEvent { Sector = Labels[1], Count = 20 },
                new WatcherEvent { Sector = Labels[2], Count = 16 },
                new WatcherEvent { Sector = Labels[3], Count = 16 },
                new WatcherEvent { Sector = Labels[4], Count = 14 },
                new WatcherEvent { Sector = Labels[5], Count = 16 },
                new WatcherEvent { Sector = Labels[6], Count = 15 },
                new WatcherEvent { Sector = Labels[7], Count = 15 },
                new WatcherEvent { Sector = Labels[8], Count = 16 },
                new WatcherEvent { Sector = Labels[9], Count = 12 },
                new WatcherEvent { Sector = Labels[10], Count = 20 },
                new WatcherEvent { Sector = Labels[11], Count = 20 },
                new WatcherEvent { Sector = Labels[12], Count = 18 },
                new WatcherEvent { Sector = Labels[13], Count = 18 },
                new WatcherEvent { Sector = Labels[14], Count = 18 },
                new WatcherEvent { Sector = Labels[15], Count = 15 },
                new WatcherEvent { Sector = Labels[16], Count = 20 },
                new WatcherEvent { Sector = Labels[17], Count = 9 },
                new WatcherEvent { Sector = Labels[18], Count = 17 },
                new WatcherEvent { Sector = Labels[19], Count = 18 },
                new WatcherEvent { Sector = Labels[20], Count = 16 },
                new WatcherEvent { Sector = Labels[21], Count = 19 },

            },
                BackgroundColor = backgroundColors[0],
                BorderColor = borderColors[0],
                Fill = true,
                PointRadius = 3,
                BorderWidth = 1,
                PointBorderColor = Enumerable.Repeat(borderColors.First(), 6).ToList(),
                CubicInterpolationMode = "monotone",
            };
    }
}
