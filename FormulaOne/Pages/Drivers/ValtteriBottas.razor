                    </tr>
                    <tr>
                        <th>Wins</th>
                        <td>
                            @if (VectorDrivers == null)
                            {
                                <p> loading</p>
                            }
                            else
                            {
                                @VectorDrivers[9].Wins
                            }
                        </td>
                    </tr>
                    <tr>
                        <th>Podiums</th>
                        <td>
                            @if (VectorDrivers == null)
                            {
                                <p> loading</p>
                            }
                            else
                            {
                                @VectorDrivers[9].Podiums
                            }
                        </td>
                    </tr>
                    <tr>
                        <th>Pole position</th>
                        <td>
                            @if (VectorDrivers == null)
                            {
                                <p> loading</p>
                            }
                            else
                            {
                                @VectorDrivers[9].PolePosition
                            }
                        </td>
                    </tr>
                    <tr>
                        <th>Fastest lap</th>
                        <td>
                            @if (VectorDrivers == null)
                            {
                                <p> loading</p>
                            }
                            else
                            {
                                @VectorDrivers[9].FastestLap
                            }
                        </td>
                    </tr>
                    <tr>
                        <th>Laps led</th>
                        <td>
                            @if (VectorDrivers == null)
                            {
                                <p> loading</p>
                            }
                            else
                            {
                                @VectorDrivers[9].LapsLed
                            }
                        </td>
                    </tr>
                    <tr>
                        <th>Points</th>
                        <td>
                            @if (VectorDrivers == null)
                            {
                                <p> loading</p>
                            }
