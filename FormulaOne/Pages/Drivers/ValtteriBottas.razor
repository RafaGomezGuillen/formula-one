                    }
                    else
                    {
                        @VectorDrivers[17].Driver
                    }
                </CardTitle>
                <CardText>
                    @if (VectorDrivers == null)
                    {
                        <p> loading</p>
                    }
                    else
                    {
                        @VectorDrivers[9].Driver
                    }
                    teammate.
                </CardText>
                <Button Margin="Margin.Is2.FromTop" Color="Color.Primary">
                    <Link To="/Drivers/GuanyuZhou" TextColor="TextColor.White">
                    READ MORE <Icon Name="IconName.ArrowRight" />
                    </Link>
                </Button>
            </CardBody>
        </Card>
        <Card>
            <CardImage Source="/img/teams/alfa-romeo/alfa-romeo-logo.png" ></CardImage>
            <CardBody>
                <CardTitle Size="5">
                    @if (VectorDrivers == null)
                    {
                        <p> loading</p>
                    }
                    else
                    {
