@page "/Drivers/GeorgeRussell"
@inject HttpClient Http

<PageTitle>George Russell</PageTitle>

<Layout>
    <LayoutHeader Fixed="true">
        <Header />
    </LayoutHeader>
    <LayoutContent style="margin-top: 70px; position: absolute;">
        <Jumbotron style="border-bottom: solid grey 5px; border-right: solid grey 5px; border-bottom-right-radius: 10px;">
            <JumbotronTitle Size="JumbotronTitleSize.Is4">
                <h1 style="font-size: 42px; line-height: 48px; letter-spacing: 0.2px">
                    @if (VectorDrivers == null)
                    {
                        <p> loading</p>
                    }
                    else
                    {
                        @VectorDrivers[3].Driver
                    }
                </h1>
            </JumbotronTitle>
            <Divider></Divider>
            <div class="row">
                <div class="column">
                    <div class="driver-logo">
                        <img src="/img/drivers-content/george-russell/logo.jpg" />
                    </div>
                    <div class="number-flag">
                        @if (DriversNumbers == null)
                        {
                            <p> loading</p>
                        }
                        else
                        {
                            @DriversNumbers[3]
                        }
                        -
                        @if (VectorDrivers == null)
                        {
                            <p> loading</p>
                        }
                        else
                        {
                            @VectorDrivers[3].Driver
                        }
                        <img src="/img/drivers/countries/Uk.jpg" />
                    </div>
                </div>
                <div class="column">
                    <div class="driver-helmet">
                        <img src="/img/teams/mercedes/mercedes-logo.jpg" />
                        <img src="/img/drivers-content/george-russell/helmet.png" />
                    </div>
                    <br />
                    <div class="team-table">
                        <table>
                            <tr>
                                <th>Position standing</th>
                                <td>
                                    @if (VectorDrivers == null)
                                    {
                                        <p> loading</p>
                                    }
                                    else
                                    {
                                        @VectorDrivers[3].Pos
                                    }
                                </td>
                            </tr>
                            <tr>
                                <th>Team</th>
                                <td>
                                    @if (VectorDrivers == null)
                                    {
                                        <p> loading</p>
                                    }
                                    else
                                    {
                                        @VectorDrivers[3].Team
                                    }
                                </td>
                            </tr>
                            <tr>
                                <th>Grand Prix entered</th>
                                <td>
                                    @if (VectorDrivers == null)
                                    {
                                        <p> loading</p>
                                    }
                                    else
                                    {
                                        @VectorDrivers[3].GrandPrix
                                    }
                                </td>
                            </tr>
                            <tr>
                                <th>Wins</th>
                                <td>
                                    @if (VectorDrivers == null)
                                    {
                                        <p> loading</p>
                                    }
                                    else
                                    {
                                        @VectorDrivers[3].Wins
                                    }
                                </td>
                            </tr>
                            <tr>
                                <th>Podiums</th>
                                <td>
                                    @if (VectorDrivers == null)
                                    {
                                        <p> loading</p>
                                    }
                                    else
                                    {
                                        @VectorDrivers[3].Podiums
                                    }
                                </td>
                            </tr>
                            <tr>
                                <th>Pole position</th>
                                <td>
                                    @if (VectorDrivers == null)
                                    {
                                        <p> loading</p>
                                    }
                                    else
                                    {
                                        @VectorDrivers[3].PolePosition
                                    }
                                </td>
                            </tr>
                            <tr>
                                <th>Fastest lap</th>
                                <td>
                                    @if (VectorDrivers == null)
                                    {
                                        <p> loading</p>
                                    }
                                    else
                                    {
                                        @VectorDrivers[3].FastestLap
                                    }
                                </td>
                            </tr>
                            <tr>
                                <th>Laps led</th>
                                <td>
                                    @if (VectorDrivers == null)
                                    {
                                        <p> loading</p>
                                    }
                                    else
                                    {
                                        @VectorDrivers[3].LapsLed
                                    }
                                </td>
                            </tr>
                            <tr>
                                <th>Points</th>
                                <td>
                                    @if (VectorDrivers == null)
                                    {
                                        <p> loading</p>
                                    }
                                    else
                                    {
                                        @VectorDrivers[3].Points
                                    }
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>
            <div class="carousel">
                <Carousel @bind-SelectedSlide="@selectedSlide" Crossfade="true" ShowControls="false" ShowIndicators="false" Interval="3000">
                    <CarouselSlide Name="1">
                        <img src="img/drivers-content/george-russell/img-1.jpg" />
                    </CarouselSlide>
                    <CarouselSlide Name="2">
                        <img src="img/drivers-content/george-russell/img-2.jpg" />
                    </CarouselSlide>
                    <CarouselSlide Name="3">
                        <img src="img/drivers-content/george-russell/img-3.jpg" />
                    </CarouselSlide>
                    <CarouselSlide Name="4">
                        <img src="img/drivers-content/george-russell/img-4.jpg" />
                    </CarouselSlide>
                </Carousel>
            </div>
            <div class="team-content">
                <h1>Biography</h1>
                <p>
                    He’s the driver with the motto: “If in doubt, go flat out”.
                    <br />
                    <br />
                    George Russell has lived by it throughout his F1 career to date, out-qualifying seasoned team mate Robert Kubica at all 21 Grands Prix in his rookie season, putting Williams back on the podium in 2021, and landing his first race win with Mercedes in 2022.
                    <br />
                    <br />
                    That brilliant baseline speed served Russell well as he totted up titles on his way to Formula 1. The Briton stormed to the 2017 GP3 championship and delivered the 2018 Formula 2 crown under immense pressure.
                    <br />
                    <br />
                    Spotting his potential, world champions Mercedes swooped to sign him to their junior programme in 2017, when Russell already had a DTM deal on the table. He banked more experience with practice sessions with Force India and tests for the Silver Arrows, before landing his Mercedes-powered Williams race drive.
                    <br />
                    <br />
                    A refusal to cede ground to his rivals - and commitment to a tricky pass – underpins Russell’s winning mentality. And it’s what got him the call-up to replace Lewis Hamilton for a one-off Mercedes appearance for Sakhir 2020 when the reigning champ was struck down by Covid-19.
                    <br />
                    <br />
                    That star turn saw Russell miss out on pole by just 0.026s and then outrace Mercedes stalwart Valtteri Bottas. Only a bungled pit stop and a heart-breaking late puncture prevented a near-certain maiden win for the up-and-coming super-sub.
                    <br />
                    <br />
                    He kept his head down at Williams in 2021, scoring his first points and podium, all the while keeping his eye on the bigger prize. Having proved himself a hard worker and a tenacious talent, that prize arrived in the form of a chance to take on compatriot and seven-time champion Hamilton in identical machinery.
                    <br />
                    <br />
                    It was an opportunity Russell relished, as he took his first F1 win – and Mercedes’ only 2022 victory – in Brazil, en route to fourth in the drivers’ championship, two places and 35 points ahead of his illustrious team mate.
                </p>
                <h1>Results</h1>
                <p>20 includes P20, DNFs, DNSs, DWs and DNPs</p>
                <div style="width: 99%">
                    <LineChart @ref="lineChart" TItem="WatcherEvent" Options="@lineChartOptions" />
                </div>
            </div>
            <CardDeck>
                <Card>
                    <CardImage Source="/img/teams/mercedes/img-1.jpg"></CardImage>
                    <CardBody>
                        <CardTitle Size="5">
                            @if (VectorDrivers == null)
                            {
                                <p> loading</p>
                            }
                            else
                            {
                                @VectorDrivers[5].Driver
                            }
                        </CardTitle>
                        <CardText>
                            @if (VectorDrivers == null)
                            {
                                <p> loading</p>
                            }
                            else
                            {
                                @VectorDrivers[3].Driver
                            }
                            teammate.
                        </CardText>
                        <Button Margin="Margin.Is2.FromTop" Color="Color.Primary">
                            <Link To="/Drivers/LewisHamilton" TextColor="TextColor.White">
                            READ MORE <Icon Name="IconName.ArrowRight" />
                            </Link>
                        </Button>
                    </CardBody>
                </Card>
                <Card>
                    <CardImage Source="/img/teams/mercedes/mercedes-logo.jpg" ></CardImage>
                    <CardBody>
                        <CardTitle Size="5">
                            @if (VectorDrivers == null)
                            {
                                <p> loading</p>
                            }
                            else
                            {
                                @VectorDrivers[3].Team
                            }
                        </CardTitle>
                        <CardText>
                            @if (VectorDrivers == null)
                            {
                                <p> loading</p>
                            }
                            else
                            {
                                @VectorDrivers[3].Driver
                            }
                            team.
                        </CardText>
                        <Button Margin="Margin.Is2.FromTop" Color="Color.Primary">
                            <Link To="/Teams/Mercedes" TextColor="TextColor.White">
                            READ MORE <Icon Name="IconName.ArrowRight" />
                            </Link>
                        </Button>
                    </CardBody>
                </Card>
                <Card>
                    <CardImage Source="/img/Changes.jpg"></CardImage>
                    <CardBody>
                        <CardTitle Size="5">Drivers</CardTitle>
                        <CardText>
                            Full drivers lineup.
                        </CardText>
                        <Button Margin="Margin.Is2.FromTop" Color="Color.Primary">
                            <Link To="/Drivers" TextColor="TextColor.White">
                            READ MORE <Icon Name="IconName.ArrowRight" />
                            </Link>
                        </Button>
                    </CardBody>
                </Card>
            </CardDeck>
        </Jumbotron>
        <Footer />
    </LayoutContent>
</Layout>

@*Theme*@
<Blazorise.ThemeProvider Theme="@theme">
    <Router AppAssembly="typeof(App).Assembly">
        <Found>...</Found>
        <NotFound>...</NotFound>
    </Router>
</Blazorise.ThemeProvider>

@code {
    private string selectedSlide = "1";

    private Theme theme = new Theme
    {
        ColorOptions = new ThemeColorOptions { Primary = "#E10600" }
    };

    private Root[]? VectorDrivers;
    private int[] DriversNumbers = { 1, 16, 11, 63, 55, 44, 4, 31, 14, 77, 3, 5, 20, 10, 18, 47, 22, 24, 23, 6 };

    protected override async Task OnInitializedAsync ()
    {
        VectorDrivers = await Http.GetFromJsonAsync<Root[]>("sample-data/DriverStatistics.json");
    }

    public class Root
    {
        public int Pos { get; set; }
        public string Driver { get; set; }
        public string Team { get; set; }
        public int GrandPrix { get; set; }
        public int Wins { get; set; }
        public int Podiums { get; set; }
        public int PolePosition { get; set; }
        public int FastestLap { get; set; }
        public int LapsLed { get; set; }
        public int Points { get; set; }
    }

    private LineChart<WatcherEvent> lineChart;

    LineChartOptions lineChartOptions = new()
        {
            Parsing = new ChartParsing
            {
                XAxisKey = "sector",
                YAxisKey = "count",
            }
        };

    string[] Labels = { "Bahrain", "Saudi Arabia", "Australia", "Emilia Romagna", "Miami", "Spain", "Monaco", "Azerbaijan", "Canada", "Great Britain", "Austria", "France",
                        "Hungary", "Belgium", "Netherlands", "Italy", "Singapore", "Japan", "United States", "Mexico", "Brazil", "Abu Dhabi"};


    private List<string> backgroundColors = new() { ChartColor.FromRgba(255, 99, 132, 0.2f) };
    private List<string> borderColors = new() { ChartColor.FromRgba(255, 99, 132, 1f) };

    private bool isAlreadyInitialised;

    public class WatcherEvent
    {
        public string Sector { get; set; }
        public int Count { get; set; }
    }

    protected override async Task OnAfterRenderAsync (bool firstRender)
    {
        if (!isAlreadyInitialised)
        {
            isAlreadyInitialised = true;
            await lineChart.Clear();
            await lineChart.AddDataSet(GetLineChartDataset());
        }
    }

    private LineChartDataset<WatcherEvent> GetLineChartDataset ()
    {
        return new()
            {
                Label = "George Russell",
                Data = new List<WatcherEvent>
            {
                new WatcherEvent { Sector = Labels[0], Count = 4 },
                new WatcherEvent { Sector = Labels[1], Count = 5 },
                new WatcherEvent { Sector = Labels[2], Count = 3 },
                new WatcherEvent { Sector = Labels[3], Count = 4 },
                new WatcherEvent { Sector = Labels[4], Count = 5 },
                new WatcherEvent { Sector = Labels[5], Count = 3 },
                new WatcherEvent { Sector = Labels[6], Count = 5 },
                new WatcherEvent { Sector = Labels[7], Count = 3 },
                new WatcherEvent { Sector = Labels[8], Count = 4 },
                new WatcherEvent { Sector = Labels[9], Count = 20 },
                new WatcherEvent { Sector = Labels[10], Count = 4 },
                new WatcherEvent { Sector = Labels[11], Count = 3 },
                new WatcherEvent { Sector = Labels[12], Count = 3 },
                new WatcherEvent { Sector = Labels[13], Count = 4 },
                new WatcherEvent { Sector = Labels[14], Count = 2 },
                new WatcherEvent { Sector = Labels[15], Count = 3 },
                new WatcherEvent { Sector = Labels[16], Count = 14 },
                new WatcherEvent { Sector = Labels[17], Count = 8 },
                new WatcherEvent { Sector = Labels[18], Count = 5 },
                new WatcherEvent { Sector = Labels[19], Count = 4 },
                new WatcherEvent { Sector = Labels[20], Count = 1 },
                new WatcherEvent { Sector = Labels[21], Count = 5 }
            },
                BackgroundColor = backgroundColors[0],
                BorderColor = borderColors[0],
                Fill = true,
                PointRadius = 3,
                BorderWidth = 1,
                PointBorderColor = Enumerable.Repeat(borderColors.First(), 6).ToList(),
                CubicInterpolationMode = "monotone",
            };
    }
}
