@page "/Drivers/SergioPerez"
@inject HttpClient Http

<PageTitle>Sergio Perez</PageTitle>

<Layout>
    <LayoutHeader Fixed="true">
        <Header />
    </LayoutHeader>
    <LayoutContent style="margin-top: 70px; position: absolute;">
        <Jumbotron style="border-bottom: solid grey 5px; border-right: solid grey 5px; border-bottom-right-radius: 10px;">
            <JumbotronTitle Size="JumbotronTitleSize.Is4">
                <h1 style="font-size: 42px; line-height: 48px; letter-spacing: 0.2px">
                    @if (VectorDrivers == null)
                    {
                        <p> loading</p>
                    }
                    else
                    {
                        @VectorDrivers[2].Driver
                    }
                </h1>
            </JumbotronTitle>
            <Divider></Divider>
            <div class="row">
                <div class="column">
                    <div class="driver-logo">
                        <img src="/img/drivers-content/sergio-perez/logo.jpg" />
                    </div>
                    <div class="number-flag">
                        @if (DriversNumbers == null)
                        {
                            <p> loading</p>
                        }
                        else
                        {
                            @DriversNumbers[2]
                        }
                        -
                        @if (VectorDrivers == null)
                        {
                            <p> loading</p>
                        }
                        else
                        {
                            @VectorDrivers[2].Driver
                        }
                        <img src="/img/drivers/countries/Mexico.jpg" />
                    </div>
                </div>
                <div class="column">
                    <div class="driver-helmet">
                        <img src="/img/teams/red-bull/red-bull-logo.jpg" />
                        <img src="/img/drivers-content/sergio-perez/helmet.png" />
                    </div>
                    <br />
                    <div class="team-table">
                        <table>
                            <tr>
                                <th>Position standing</th>
                                <td>
                                    @if (VectorDrivers == null)
                                    {
                                        <p> loading</p>
                                    }
                                    else
                                    {
                                        @VectorDrivers[2].Pos
                                    }
                                </td>
                            </tr>
                            <tr>
                                <th>Team</th>
                                <td>
                                    @if (VectorDrivers == null)
                                    {
                                        <p> loading</p>
                                    }
                                    else
                                    {
                                        @VectorDrivers[2].Team
                                    }
                                </td>
                            </tr>
                            <tr>
                                <th>Grand Prix entered</th>
                                <td>
                                    @if (VectorDrivers == null)
                                    {
                                        <p> loading</p>
                                    }
                                    else
                                    {
                                        @VectorDrivers[2].GrandPrix
                                    }
                                </td>
                            </tr>
                            <tr>
                                <th>Wins</th>
                                <td>
                                    @if (VectorDrivers == null)
                                    {
                                        <p> loading</p>
                                    }
                                    else
                                    {
                                        @VectorDrivers[2].Wins
                                    }
                                </td>
                            </tr>
                            <tr>
                                <th>Podiums</th>
                                <td>
                                    @if (VectorDrivers == null)
                                    {
                                        <p> loading</p>
                                    }
                                    else
                                    {
                                        @VectorDrivers[2].Podiums
                                    }
                                </td>
                            </tr>
                            <tr>
                                <th>Pole position</th>
                                <td>
                                    @if (VectorDrivers == null)
                                    {
                                        <p> loading</p>
                                    }
                                    else
                                    {
                                        @VectorDrivers[2].PolePosition
                                    }
                                </td>
                            </tr>
                            <tr>
                                <th>Fastest lap</th>
                                <td>
                                    @if (VectorDrivers == null)
                                    {
                                        <p> loading</p>
                                    }
                                    else
                                    {
                                        @VectorDrivers[2].FastestLap
                                    }
                                </td>
                            </tr>
                            <tr>
                                <th>Laps led</th>
                                <td>
                                    @if (VectorDrivers == null)
                                    {
                                        <p> loading</p>
                                    }
                                    else
                                    {
                                        @VectorDrivers[2].LapsLed
                                    }
                                </td>
                            </tr>
                            <tr>
                                <th>Points</th>
                                <td>
                                    @if (VectorDrivers == null)
                                    {
                                        <p> loading</p>
                                    }
                                    else
                                    {
                                        @VectorDrivers[2].Points
                                    }
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>
            <div class="carousel">
                <Carousel @bind-SelectedSlide="@selectedSlide" Crossfade="true" ShowControls="false" ShowIndicators="false" Interval="3000">
                    <CarouselSlide Name="1">
                        <img src="img/drivers-content/sergio-perez/img-1.jpg" />
                    </CarouselSlide>
                    <CarouselSlide Name="2">
                        <img src="img/drivers-content/sergio-perez/img-2.jpg" />
                    </CarouselSlide>
                    <CarouselSlide Name="3">
                        <img src="img/drivers-content/sergio-perez/img-3.jpg" />
                    </CarouselSlide>
                    <CarouselSlide Name="4">
                        <img src="img/drivers-content/sergio-perez/img-4.jpg" />
                    </CarouselSlide>
                </Carousel>
            </div>
            <div class="team-content">
                <h1>Biography</h1>
                <p>
                    He’s the fighter with a gentle touch from the land of the Lucha Libre.
                    <br />
                    <br />
                    Perez’s reputation in F1 has been built on opposite approaches to Grand Prix racing. On the one hand, he is a punchy combatant who wrestles his way through the pack and into the points. Never afraid to add a bit of spice to his on-track encounters, even his team mates don’t always escape the Mexican’s heat.
                    <br />
                    <br />
                    Then on the other hand, Perez is a smooth operator, a master at managing tyres to eke out extra performance and give him the upper hand on strategy. A firm favourite on the grid after his time with Sauber, McLaren, Force India and Racing Point, Perez has matured into an analytical racer and team player.
                    <br />
                    <br />
                    A proud countryman, the Guadalajara gunslinger has amassed more points than any other Mexican in the history of F1. In Sakhir 2020 he also matched hero and compatriot Pedro Rodriguez by taking the chequered flag in first – a performance that landed him a seat with title contenders Red Bull.
                    <br />
                    <br />
                    There he provided strong support to Max Verstappen’s 2021 and '22 championship-winning campaigns, also adding a further three victories to his own tally. More wins may not be assured, especially with Verstappen as team mate, but Perez working hard and racing with his heart are.
                </p>
                <h1>Results</h1>
                <p>20 includes P20, DNFs, DNSs, DWs and DNPs</p>
                <div style="width: 99%">
                    <LineChart @ref="lineChart" TItem="WatcherEvent" Options="@lineChartOptions" />
                </div>
            </div>
            <CardDeck>
                <Card>
                    <CardImage Source="/img/teams/red-bull/img-3.jpg"></CardImage>
                    <CardBody>
                        <CardTitle Size="5">
                            @if (VectorDrivers == null)
                            {
                                <p> loading</p>
                            }
                            else
                            {
                                @VectorDrivers[0].Driver
                            }
                        </CardTitle>
                        <CardText>
                            @if (VectorDrivers == null)
                            {
                                <p> loading</p>
                            }
                            else
                            {
                                @VectorDrivers[2].Driver
                            }
                            teammate.
                        </CardText>
                        <Button Margin="Margin.Is2.FromTop" Color="Color.Primary">
                            <Link To="/Drivers/MaxVerstappen" TextColor="TextColor.White">
                            READ MORE <Icon Name="IconName.ArrowRight" />
                            </Link>
                        </Button>
                    </CardBody>
                </Card>
                <Card>
                    <CardImage Source="/img/teams/red-bull/red-bull-logo.jpg" ></CardImage>
                    <CardBody>
                        <CardTitle Size="5">
                            @if (VectorDrivers == null)
                            {
                                <p> loading</p>
                            }
                            else
                            {
                                @VectorDrivers[2].Team
                            }
                        </CardTitle>
                        <CardText>
                            @if (VectorDrivers == null)
                            {
                                <p> loading</p>
                            }
                            else
                            {
                                @VectorDrivers[2].Driver
                            }
                            team.
                        </CardText>
                        <Button Margin="Margin.Is2.FromTop" Color="Color.Primary">
                            <Link To="/Teams/RedBull" TextColor="TextColor.White">
                            READ MORE <Icon Name="IconName.ArrowRight" />
                            </Link>
                        </Button>
                    </CardBody>
                </Card>
                <Card>
                    <CardImage Source="/img/Changes.jpg"></CardImage>
                    <CardBody>
                        <CardTitle Size="5">Drivers</CardTitle>
                        <CardText>
                            Full drivers lineup.
                        </CardText>
                        <Button Margin="Margin.Is2.FromTop" Color="Color.Primary">
                            <Link To="/Drivers" TextColor="TextColor.White">
                            READ MORE <Icon Name="IconName.ArrowRight" />
                            </Link>
                        </Button>
                    </CardBody>
                </Card>
            </CardDeck>
        </Jumbotron>
        <Footer />
    </LayoutContent>
</Layout>

@*Theme*@
<Blazorise.ThemeProvider Theme="@theme">
    <Router AppAssembly="typeof(App).Assembly">
        <Found>...</Found>
        <NotFound>...</NotFound>
    </Router>
</Blazorise.ThemeProvider>

@code {
    private string selectedSlide = "1";

    private Theme theme = new Theme
    {
        ColorOptions = new ThemeColorOptions { Primary = "#E10600" }
    };

    private Root[]? VectorDrivers;
    private int[] DriversNumbers = { 1, 16, 11, 63, 55, 44, 4, 31, 14, 77, 3, 5, 20, 10, 18, 47, 22, 24, 23, 6 };

    protected override async Task OnInitializedAsync ()
    {
        VectorDrivers = await Http.GetFromJsonAsync<Root[]>("sample-data/DriverStatistics.json");
    }

    public class Root
    {
        public int Pos { get; set; }
        public string Driver { get; set; }
        public string Team { get; set; }
        public int GrandPrix { get; set; }
        public int Wins { get; set; }
        public int Podiums { get; set; }
        public int PolePosition { get; set; }
        public int FastestLap { get; set; }
        public int LapsLed { get; set; }
        public int Points { get; set; }
    }

    private LineChart<WatcherEvent> lineChart;

    LineChartOptions lineChartOptions = new()
        {
            Parsing = new ChartParsing
            {
                XAxisKey = "sector",
                YAxisKey = "count",
            }
        };

    string[] Labels = { "Bahrain", "Saudi Arabia", "Australia", "Emilia Romagna", "Miami", "Spain", "Monaco", "Azerbaijan", "Canada", "Great Britain", "Austria", "France",
                        "Hungary", "Belgium", "Netherlands", "Italy", "Singapore", "Japan", "United States", "Mexico", "Brazil", "Abu Dhabi"};


    private List<string> backgroundColors = new() { ChartColor.FromRgba(255, 99, 132, 0.2f) };
    private List<string> borderColors = new() { ChartColor.FromRgba(255, 99, 132, 1f) };

    private bool isAlreadyInitialised;

    public class WatcherEvent
    {
        public string Sector { get; set; }
        public int Count { get; set; }
    }

    protected override async Task OnAfterRenderAsync (bool firstRender)
    {
        if (!isAlreadyInitialised)
        {
            isAlreadyInitialised = true;
            await lineChart.Clear();
            await lineChart.AddDataSet(GetLineChartDataset());
        }
    }

    private LineChartDataset<WatcherEvent> GetLineChartDataset ()
    {
        return new()
            {
                Label = "Sergio Pérez",
                Data = new List<WatcherEvent>
            {
                new WatcherEvent { Sector = Labels[0], Count = 18 },
                new WatcherEvent { Sector = Labels[1], Count = 4 },
                new WatcherEvent { Sector = Labels[2], Count = 2 },
                new WatcherEvent { Sector = Labels[3], Count = 2 },
                new WatcherEvent { Sector = Labels[4], Count = 4 },
                new WatcherEvent { Sector = Labels[5], Count = 2 },
                new WatcherEvent { Sector = Labels[6], Count = 1 },
                new WatcherEvent { Sector = Labels[7], Count = 2 },
                new WatcherEvent { Sector = Labels[8], Count = 20 },
                new WatcherEvent { Sector = Labels[9], Count = 2 },
                new WatcherEvent { Sector = Labels[10], Count = 20 },
                new WatcherEvent { Sector = Labels[11], Count = 4 },
                new WatcherEvent { Sector = Labels[12], Count = 5 },
                new WatcherEvent { Sector = Labels[13], Count = 2 },
                new WatcherEvent { Sector = Labels[14], Count = 5 },
                new WatcherEvent { Sector = Labels[15], Count = 6 },
                new WatcherEvent { Sector = Labels[16], Count = 1 },
                new WatcherEvent { Sector = Labels[17], Count = 2 },
                new WatcherEvent { Sector = Labels[18], Count = 4 },
                new WatcherEvent { Sector = Labels[19], Count = 3 },
                new WatcherEvent { Sector = Labels[20], Count = 7 },
                new WatcherEvent { Sector = Labels[21], Count = 3 },
            },
                BackgroundColor = backgroundColors[0],
                BorderColor = borderColors[0],
                Fill = true,
                PointRadius = 3,
                BorderWidth = 1,
                PointBorderColor = Enumerable.Repeat(borderColors.First(), 6).ToList(),
                CubicInterpolationMode = "monotone",
            };
    }
}
